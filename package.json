{
  "name": "track-my-mile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:local": "eas build --platform android --profile preview --local",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "lint": "biome lint ./src ./app",
    "lint:fix": "biome lint --write ./src ./app",
    "format": "biome format --write ./src ./app",
    "check": "biome check --write ./src ./app",
    "typecheck": "tsc --noEmit",
    "prebuild": "expo prebuild --clean"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "base64-js": "^1.5.1",
    "buffer": "^6.0.3",
    "expo": "55.0.6",
    "expo-constants": "~55.0.7",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.5",
    "expo-screen-orientation": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-ble-plx": "^3.5.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-paper": "^5.13.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@biomejs/biome": "^1.9.4",
    "@react-native-community/cli": "^20.1.2",
    "@react-native-community/cli-platform-android": "^20.1.2",
    "@react-native-community/cli-platform-ios": "^20.1.2",
    "@types/react": "~19.2.10",
    "typescript": "^5.8.0"
  },
  "private": true
}
