{
  "name": "track-my-mile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:android": "eas build --platform android --profile preview",
    "lint": "biome lint ./src ./app",
    "lint:fix": "biome lint --write ./src ./app",
    "format": "biome format --write ./src ./app",
    "check": "biome check --write ./src ./app",
    "typecheck": "tsc --noEmit",
    "prebuild": "expo prebuild --clean",
    "postprebuild": "node scripts/fix-gradle.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.4",
    "base64-js": "^1.5.1",
    "buffer": "^6.0.3",
    "expo": "55.0.6",
    "expo-constants": "18.0.13",
    "expo-font": "14.0.11",
    "expo-linking": "7.0.5",
    "expo-router": "5.0.7",
    "expo-screen-orientation": "9.0.8",
    "expo-status-bar": "2.2.3",
    "react": "19.0.0",
    "react-native": "0.79.2",
    "react-native-ble-plx": "^3.5.1",
    "react-native-gesture-handler": "2.24.0",
    "react-native-paper": "^5.13.1",
    "react-native-reanimated": "3.17.5",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "4.10.0",
    "react-native-svg": "15.11.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@biomejs/biome": "^1.9.4",
    "@types/react": "~19.0.0",
    "typescript": "^5.8.0"
  },
  "private": true
}